{
  "name": "ninja-terminals",
  "version": "2.2.0",
  "description": "MCP server for multi-terminal Claude Code orchestration with DAG task management, parallel execution, and self-improvement",
  "main": "server.js",
  "bin": {
    "ninja-terminals": "cli.js",
    "ninja-terminals-mcp": "mcp-server.js"
  },
  "scripts": {
    "start": "node server.js",
    "mcp": "node mcp-server.js"
  },
  "files": [
    "lib/",
    "public/",
    "orchestrator/playbooks.md",
    "orchestrator/identity.md",
    "orchestrator/security-protocol.md",
    "orchestrator/tool-registry.md",
    "orchestrator/evolution-log.md",
    "orchestrator/metrics/.gitkeep",
    "orchestrator/metrics/raw/.gitkeep",
    "prompts/",
    "cli.js",
    "server.js",
    "mcp-server.js",
    "CLAUDE.md",
    "ORCHESTRATOR-PROMPT.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "terminal",
    "orchestrator",
    "agents",
    "multi-agent",
    "mcp",
    "model-context-protocol",
    "mcp-server"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmos82/ninja-terminals.git"
  },
  "homepage": "https://ninjaterminals.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.2.0-beta.10",
    "ws": "^8.19.0"
  }
}
